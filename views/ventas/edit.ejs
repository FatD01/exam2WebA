<%- include('../partials/header') %>

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="card-title mb-0"><i class="bi bi-pencil-square"></i> Editar Venta</h4>
            </div>
            <div class="card-body p-4">
                <form action="/ventas/editar/<%= venta.id_venta %>" method="POST">
                    <div class="mb-4">
                        <label for="fecha" class="form-label fw-bold">Fecha de la Venta</label>
                        <% 
                            // Formateamos la fecha para que el input type="date" la pueda leer (YYYY-MM-DD)
                            const d = new Date(venta.fecha);
                            let month = '' + (d.getMonth() + 1);
                            let day = '' + d.getDate();
                            const year = d.getFullYear();

                            if (month.length < 2) month = '0' + month;
                            if (day.length < 2) day = '0' + day;

                            const fechaInput = [year, month, day].join('-');
                        %>
                        <input type="date" class="form-control form-control-lg" id="fecha" name="fecha" value="<%= fechaInput %>" required>
                    </div>
                    
                    <div class="mb-4">
                        <label for="total" class="form-label fw-bold">Total ($)</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" class="form-control" id="total" name="total" value="<%= venta.total %>" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="id_vendedor" class="form-label fw-bold">Vendedor Asignado</label>
                        <select class="form-select form-select-lg" id="id_vendedor" name="id_vendedor" required>
                            <!-- Llenamos el select marcando el vendedor actual -->
                            <% vendedores.forEach(function(v) { %>
                                <option value="<%= v.id_vendedor %>" <%= venta.id_vendedor === v.id_vendedor ? 'selected' : '' %>>
                                    <%= v.nombre %>
                                </option>
                            <% }); %>
                        </select>
                    </div>
                    
                    <div class="d-flex justify-content-between mt-4">
                        <a href="/ventas" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
                        <button type="submit" class="btn btn-warning px-4 text-dark fw-bold"><i class="bi bi-save"></i> Actualizar Venta</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
