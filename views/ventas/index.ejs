<%- include('../partials/header') %>

    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h2 class="fw-bold text-success"><i class="bi bi-graph-up-arrow"></i> Lista de Ventas</h2>
        <a href="/ventas/crear" class="btn btn-success"><i class="bi bi-plus-circle"></i> Registrar Venta</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID Venta</th>
                            <th>Fecha</th>
                            <th>Vendedor</th>
                            <th>Total (S/)</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(ventas.length> 0) { %>
                            <% ventas.forEach(function(venta) { %>
                                <tr>
                                    <td>
                                        <%= venta.id_venta %>
                                    </td>
                                    <!-- Formateamos la fecha para que se vea bonita -->
                                    <td>
                                        <% const d=new Date(venta.fecha); const
                                            fechaFormateada=d.toLocaleDateString('es-ES'); %>
                                            <i class="bi bi-calendar-event text-muted"></i>
                                            <%= fechaFormateada %>
                                    </td>
                                    <!-- Aquí mostramos el nombre obtenido con INNER JOIN -->
                                    <td class="fw-medium text-primary"><i class="bi bi-person"></i>
                                        <%= venta.nombre_vendedor %>
                                    </td>
                                    <td class="fw-bold text-success">S/<%= venta.total %>
                                    </td>
                                    <td class="text-end">
                                        <a href="/ventas/editar/<%= venta.id_venta %>"
                                            class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil-square"></i> Editar
                                        </a>
                                        <a href="/ventas/eliminar/<%= venta.id_venta %>"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('¿Estás seguro de eliminar este registro de venta?');">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="5" class="text-center py-4 text-muted">No hay ventas
                                                registradas todavía.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>