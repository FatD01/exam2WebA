<%- include('partials/header') %>

<div class="row justify-content-center mt-5">
    <div class="col-md-8 text-center">
        <h1 class="display-4 fw-bold text-primary mb-4">Bienvenido al Sistema de Ventas</h1>
        <p class="lead text-secondary mb-5">Examen Práctico: CRUD de Vendedores y Ventas con Node.js, Express y MySQL.</p>
        
        <div class="row g-4">
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">
                        <div class="display-1 text-primary mb-3"><i class="bi bi-people-fill"></i></div>
                        <h3 class="card-title h4 fw-bold">Vendedores</h3>
                        <p class="card-text text-muted">Gestiona el personal de ventas. Puedes agregar, editar, eliminar y subir la foto de perfil de cada vendedor.</p>
                        <a href="/vendedores" class="btn btn-outline-primary mt-2">Ir a Vendedores</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                    <div class="card-body p-4">
                        <div class="display-1 text-success mb-3"><i class="bi bi-graph-up-arrow"></i></div>
                        <h3 class="card-title h4 fw-bold">Ventas</h3>
                        <p class="card-text text-muted">Administra los registros de ventas. Asigna ventas a vendedores específicos y controla los montos.</p>
                        <a href="/ventas" class="btn btn-outline-success mt-2">Ir a Ventas</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
